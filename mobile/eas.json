{
  "cli": {
    "appVersionSource": "remote",
    "version": ">= 20.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "channel": "preview",
      "autoIncrement": true
    },
    "internal": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "channel": "internal",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_ENV": "staging"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "simulator": false
      },
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "Nathanielclarke2306@gmail.com",
        "ascAppId": "6775850115",
        "appleTeamId": "3R5R4VJ329"
      }
    }
  }
}
