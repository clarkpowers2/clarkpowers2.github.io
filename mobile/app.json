{
  "expo": {
    "name": "FreshSave Staff",
    "slug": "freshsave-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "freshsavemobile",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios"
    ],
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.freshsave.staff",
      "buildNumber": "1.0.4",
      "supportsTablet": false,
      "requireFullScreen": true,
      "infoPlist": {
        "NSCameraUsageDescription": "FreshSave Staff needs camera access to scan product barcodes and expiry dates.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "fetch"
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF"
        }
      ],
      "expo-status-bar",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow FreshSave Staff to access your camera to scan barcodes and expiry dates on products."
        }
      ],
      "expo-image",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "FreshSave Staff needs camera access to scan product barcodes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "827d3726-88fa-4ae2-b75d-297498132307"
      }
    },
    "owner": "clarkpowers",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ups": {
      "url": "https://u.expo.dev/827d3726-88fa-4ae2-b75d-297498132307"
    }
  }
}